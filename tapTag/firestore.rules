rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Global seeded knowledge docs used by the app.
    match /cards/{cardId} {
      allow read: if true;
      allow write: if false;
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if false;
    }

    match /mcc_map/{mccId} {
      allow read: if true;
      allow write: if false;
    }

    // User profile and app-owned subcollections.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /wallet/{cardProductId} {
        allow read, write: if isOwner(uid);
      }

      match /events/{eventId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
